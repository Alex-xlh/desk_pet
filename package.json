{
  "name": "desktop-mouse-pet",
  "version": "0.1.0",
  "description": "A lightweight Windows desktop pet that follows the mouse.",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "tauri dev",
    "dev:renderer": "vite --host 127.0.0.1",
    "build": "tauri build",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "generate:assets": "powershell -ExecutionPolicy Bypass -File scripts/create-placeholder-spritesheet.ps1",
    "tauri": "tauri"
  },
  "build": {
    "appId": "com.alex-xlh.desk-pet",
    "productName": "Desktop Mouse Pet",
    "icon": "assets/pets/default/preview.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "package.json",
      "panel.html"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "pixi.js": "^8.14.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
