{
  "name": "desktop-mouse-pet",
  "version": "0.1.0",
  "description": "A lightweight Windows desktop pet that follows the mouse.",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "npm run build:main && node scripts/dev.mjs",
    "start": "electron .",
    "dev:renderer": "vite --host 127.0.0.1",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "generate:assets": "powershell -ExecutionPolicy Bypass -File scripts/create-placeholder-spritesheet.ps1"
  },
  "dependencies": {
    "pixi.js": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "electron": "^33.4.11",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
